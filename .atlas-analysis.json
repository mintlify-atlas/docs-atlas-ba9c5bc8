  "keyFeatures": [
    "Embedded, serverless graph database — no separate server process required",
    "Cypher query language with full read/write support",
    "Native full-text search (FTS) and vector indexing built in",
    "Columnar disk-based storage with CSR adjacency list indices",
    "Multi-core query parallelism with vectorized query processor",
    "ACID transactions with serializable isolation",
    "WebAssembly (Wasm) bindings for browser-based execution",
    "Rich extension system: algo, json, httpfs, duckdb, postgres, and more",
    "Multi-language APIs: Python, Node.js, Java, Rust, C/C++",
    "PyTorch Geometric integration for graph ML workloads"
  ],
  "publicApiSurface": [
    "kuzu.Database(database_path, buffer_pool_size, max_num_threads, compression, read_only)",
    "kuzu.Connection(database, num_threads)",
    "Connection.execute(query, parameters) -> QueryResult",
    "Connection.create_function(name, udf, params_type, return_type)",
    "QueryResult.has_next() / get_next() / as_df() / as_arrow()",
    "Database.get_torch_geometric_remote_backend()",
    "C API: kuzu_database_init / kuzu_connection_init / kuzu_connection_query",
    "INSTALL <extension> FROM '<server>'",
    "CALL fts_index('table', ['col1', 'col2'])",
    "CALL vector_index('table', 'col', 'cosine')",
    "MATCH / CREATE / MERGE / DELETE / SET (Cypher DML)",
    "CREATE NODE TABLE / CREATE REL TABLE (Cypher DDL)",
    "COPY FROM (CSV, Parquet, JSON bulk import)"
  ]
